#!/bin/sh

repo_root=$(git rev-parse --show-toplevel) || exit 1
cd "$repo_root" || exit 1

if ! cargo fmt --all --check; then
    echo "pre-commit: cargo fmt --all --check failed" >&2
    exit 1
fi

if ! cargo clippy --workspace --all-targets -- -D warnings; then
    echo "pre-commit: cargo clippy --workspace --all-targets -- -D warnings failed" >&2
    exit 1
fi

if ! cargo check --workspace --all-targets; then
    echo "pre-commit: cargo check --workspace --all-targets failed" >&2
    exit 1
fi
